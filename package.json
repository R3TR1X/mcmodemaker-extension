{
    "name": "mcmodmaker",
    "displayName": "Minecraft Mod",
    "description": "A VS Code extension for creating Minecraft Mods",
    "version": "0.0.1",
    "publisher": "R3TR1X",
    "repository": {
        "type": "git",
        "url": "https://github.com/R3TR1X/mcmodemaker-extension"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "mcmodmaker-explorer",
                    "title": "Minecraft Mod",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "mcmodmaker-explorer": [
                {
                    "id": "mcmodmaker.modFiles",
                    "name": "Mod Files"
                },
                {
                    "id": "mcmodmaker.modTools",
                    "name": "Mod Tools"
                }
            ]
        },
        "commands": [
            {
                "command": "mcmodmaker.createMod",
                "title": "Create Mod"
            },
            {
                "command": "mcmodmaker.addCommand",
                "title": "Add Command"
            },
            {
                "command": "mcmodmaker.addEventListener",
                "title": "Add Event Listener"
            },
            {
                "command": "mcmodmaker.addConfigFile",
                "title": "Add Config File"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.1.3"
    },
    "dependencies": {
        "axios": "^1.13.5"
    }
}